# Copia este archivo como .env y completa los valores.
# NUNCA commitees el .env real — está en .gitignore.

# Workspace API key (sk-ant-api03-...)
# Úsala para Messages API, Files API, Tool use, MCP, Managed Agents (cualquier
# request contra /v1/messages, /v1/files, /v1/agents, etc.).
# Se crea desde platform.claude.com → Workspace settings → API keys.
ANTHROPIC_API_KEY=

# Admin API key (sk-ant-admin01-...)
# Úsala SOLO para gestión de la organización: /v1/admin/*, reportes de uso,
# gestión de workspaces y miembros. NO la expongas en código cliente.
# Se crea desde platform.claude.com → Admin keys. Requiere rol Admin de la org.
# Déjala vacía si todavía no estás en el Módulo 11.
ANTHROPIC_ADMIN_API_KEY=

# Modelo por defecto para ejercicios donde el costo importa (la mayoría).
# Cámbialo a claude-sonnet-4-6 si necesitas más calidad, o claude-opus-4-6
# para razonamiento profundo (ver docs/conventions.md).
DEFAULT_MODEL=claude-haiku-4-5
